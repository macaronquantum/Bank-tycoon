generator client { provider = "prisma-client-js" }
datasource db { provider = "postgresql" url = env("DATABASE_URL") }

enum BankArchetype { POPULAR PREMIUM ENTREPRENEURIAL NEOBANK INVESTMENT }
enum SegmentType { POPULAR MIDDLE PREMIUM ULTRA_RICH SME STARTUP CORP INSTITUTION }
enum LoanStatus { PENDING ACTIVE DEFAULTED REPAID }
enum EventType { MACRO REGULATORY CRISIS BANK }

model User { id String @id @default(cuid()) email String @unique passwordHash String bank Bank? createdAt DateTime @default(now()) }
model Bank { id String @id @default(cuid()) userId String @unique user User @relation(fields:[userId], references:[id]) name String countryId String country Country @relation(fields:[countryId], references:[id]) archetype BankArchetype capital Float deposits Float @default(0) liquidity Float @default(0) reputation Float @default(50) regulatoryScore Float @default(100) branches Branch[] employees Employee[] loans Loan[] loanApplications LoanApplication[] positions AssetPosition[] checks RegulatoryCheck[] snapshots BankSnapshot[] notifications Notification[] departments Department[] createdAt DateTime @default(now()) updatedAt DateTime @updatedAt }
model Country { id String @id @default(cuid()) name String code String @unique currency String stability Float regulation Float inflation Float baseRate Float capitalMin Float liquidityMin Float concentrationLimit Float marketExposureLimit Float interbankLimit Float licenseSpeed Float complianceCost Float cities City[] banks Bank[] districts District[] profiles RegulatoryProfile[] }
model City { id String @id @default(cuid()) countryId String country Country @relation(fields:[countryId], references:[id]) name String population Int avgIncome Float unemployment Float growth Float districts District[] }
model District { id String @id @default(cuid()) countryId String country Country @relation(fields:[countryId], references:[id]) cityId String city City @relation(fields:[cityId], references:[id]) name String wealth Float realEstateCost Float competition Float crimeRisk Float depositPotential Float loanPotential Float segments Json branches Branch[] }
model Branch { id String @id @default(cuid()) bankId String bank Bank @relation(fields:[bankId], references:[id]) districtId String district District @relation(fields:[districtId], references:[id]) name String openingCost Float rentCost Float capacity Int prestige Float security Float digital Float compliance Float satisfaction Float profitability Float deposits Float @default(0) loans Float @default(0) fees Float @default(0) localReputation Float @default(50) cohorts CustomerCohort[] employees Employee[] }
model Employee { id String @id @default(cuid()) bankId String bank Bank @relation(fields:[bankId], references:[id]) branchId String? branch Branch? @relation(fields:[branchId], references:[id]) role String salary Float level Int experience Float sales Float relationSkill Float riskSkill Float complianceSkill Float efficiency Float ambition Float loyalty Float specialty String traits String[] }
model CustomerCohort { id String @id @default(cuid()) branchId String branch Branch @relation(fields:[branchId], references:[id]) segment SegmentType clients Int avgIncome Float avgDeposit Float recurringDeposit Float avgFees Float creditDemandProb Float avgCreditReq Float feeSensitivity Float repSensitivity Float depositVolatility Float defaultProb Float serviceDemand Float }
model DepositBucket { id String @id @default(cuid()) bankId String segment SegmentType amount Float stability Float concentration Float cost Float createdAt DateTime @default(now()) }
model LoanApplication { id String @id @default(cuid()) bankId String bank Bank @relation(fields:[bankId], references:[id]) segment SegmentType amount Float durationSec Int proposedRate Float minRate Float estimatedDefault Float hiddenDefault Float guarantees Float countryId String sector String score Float decision String @default("PENDING") createdAt DateTime @default(now()) }
model Loan { id String @id @default(cuid()) bankId String bank Bank @relation(fields:[bankId], references:[id]) applicationId String? status LoanStatus principal Float remaining Float rate Float durationSec Int startedAt DateTime @default(now()) nextDueAt DateTime payments LoanPayment[] }
model LoanPayment { id String @id @default(cuid()) loanId String loan Loan @relation(fields:[loanId], references:[id]) dueAt DateTime paidAt DateTime? principalPaid Float interestPaid Float status String }
model AssetPosition { id String @id @default(cuid()) bankId String bank Bank @relation(fields:[bankId], references:[id]) instrumentId String instrument MarketInstrument @relation(fields:[instrumentId], references:[id]) amount Float expectedYield Float realizedYield Float volatility Float liquidity Float duration Float defaultRisk Float marketRisk Float country String sector String }
model MarketInstrument { id String @id @default(cuid()) name String category String baseYield Float volatility Float liquidity Float riskWeight Float positions AssetPosition[] }
model RegulatoryProfile { id String @id @default(cuid()) countryId String country Country @relation(fields:[countryId], references:[id]) name String json Json }
model RegulatoryCheck { id String @id @default(cuid()) bankId String bank Bank @relation(fields:[bankId], references:[id]) countryId String level Int message String penalty Float createdAt DateTime @default(now()) }
model BankRatioSnapshot { id String @id @default(cuid()) bankId String capitalRatio Float liquidityRatio Float depositConcentration Float interbankExposure Float countryExposure Float complianceRatio Float reputation Float createdAt DateTime @default(now()) }
model Department { id String @id @default(cuid()) bankId String bank Bank @relation(fields:[bankId], references:[id]) name String level Int @default(1) upgrades DepartmentUpgrade[] }
model DepartmentUpgrade { id String @id @default(cuid()) departmentId String department Department @relation(fields:[departmentId], references:[id]) cost Float effect Json createdAt DateTime @default(now()) }
model InterbankLoan { id String @id @default(cuid()) lenderBankId String borrowerBankId String amount Float rate Float dueAt DateTime status String @default("ACTIVE") }
model LiquidityLine { id String @id @default(cuid()) providerBankId String receiverBankId String limitAmount Float usedAmount Float rate Float }
model Alliance { id String @id @default(cuid()) name String members AllianceMember[] }
model AllianceMember { id String @id @default(cuid()) allianceId String alliance Alliance @relation(fields:[allianceId], references:[id]) bankId String role String }
model Fund { id String @id @default(cuid()) bankId String strategy String mgmtFee Float perfFee Float risk Float liquidity Float reputation Float aum Float subscriptions FundSubscription[] }
model FundSubscription { id String @id @default(cuid()) fundId String fund Fund @relation(fields:[fundId], references:[id]) bankId String amount Float createdAt DateTime @default(now()) }
model StructuredProduct { id String @id @default(cuid()) bankId String type String yield Float risk Float complexity Float legalRisk Float repImpact Float regImpact Float }
model Event { id String @id @default(cuid()) type EventType title String cause String intensity Float durationSec Int countries String[] effects EventEffect[] createdAt DateTime @default(now()) endsAt DateTime }
model EventEffect { id String @id @default(cuid()) eventId String event Event @relation(fields:[eventId], references:[id]) target String metric String delta Float }
model SimulationTick { id Int @id @default(autoincrement()) tickAt DateTime @unique processed Boolean @default(false) }
model BankSnapshot { id String @id @default(cuid()) bankId String bank Bank @relation(fields:[bankId], references:[id]) value Float capital Float deposits Float liquidity Float profit Float reputation Float createdAt DateTime @default(now()) }
model Notification { id String @id @default(cuid()) bankId String bank Bank @relation(fields:[bankId], references:[id]) type String message String severity String createdAt DateTime @default(now()) read Boolean @default(false) }
model Season { id String @id @default(cuid()) name String startsAt DateTime endsAt DateTime active Boolean @default(true) leaderboard LeaderboardEntry[] }
model LeaderboardEntry { id String @id @default(cuid()) seasonId String season Season @relation(fields:[seasonId], references:[id]) bankId String score Float metric Json rank Int }
model TransactionLedger { id String @id @default(cuid()) bankId String type String amount Float metadata Json createdAt DateTime @default(now()) }
model AuditLog { id String @id @default(cuid()) actorUserId String? action String entity String entityId String payload Json createdAt DateTime @default(now()) }
